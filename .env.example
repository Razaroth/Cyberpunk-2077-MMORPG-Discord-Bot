# Your Discord bot token — get it from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# Your bot's Application ID (found on the developer portal)
APPLICATION_ID=1508891472248701070

# Bot prefix for legacy text commands
BOT_PREFIX=!

# Path to the SQLite database file
DATABASE_PATH=cyberpunk.db

# (Optional) Sync slash commands to a specific guild for faster testing.
# Leave blank to sync globally (can take up to 1 hour to propagate).
GUILD_ID=1092659554199797860
